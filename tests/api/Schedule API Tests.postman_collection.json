        {
          "name": "POST Create Room",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "let uniqueName = \"Room-\" + Date.now();\r",
                  "pm.environment.set(\"randomRoomName\", uniqueName);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is successful (200/201)\", function () {\r",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 201]);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Response has ID and save it\", function () {\r",
                  "    var jsonData = pm.response.json();\r",
                  "    pm.expect(jsonData.id).to.exist;\r",
                  "    pm.environment.set(\"roomId\", jsonData.id);\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\r\n  \"name\": \"{{randomRoomName}}\",\r\n  \"capacity\": 30\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/rooms",
